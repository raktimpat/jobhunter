# ── Google ──────────────────────────────────────────────────────────────
GOOGLE_CREDENTIALS_PATH=
SHEET_ID=
DRIVE_FOLDER_ID=
RESUME_FILE_ID=

# ── AI Model — set ONE provider ─────────────────────────────────────────
AI_PROVIDER=gemini
# AI_PROVIDER=claude

GEMINI_API_KEY=your_gemini_api_key_here
# Gemini model — update here if Google deprecates the model
# Run: python -c "from google import genai; from dotenv import load_dotenv; import os; load_dotenv(); [print(m.name) for m in genai.Client(api_key=os.environ['GEMINI_API_KEY']).models.list()]"
GEMINI_MODEL=gemini-2.5-flash
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Slack (optional — leave blank to skip notifications) ─────────────────
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=

# ── Scraper settings ─────────────────────────────────────────────────────
MAX_ITEMS=200
# r86400=last 24h  r604800=last 7 days  r2592000=last 30 days
PUBLISH_WITHIN=r604800

# ── Scoring threshold ────────────────────────────────────────────────────
# Jobs with AI match score below this are discarded
AI_SCORE_THRESHOLD=55

# Scraper debug — dumps raw LinkedIn HTML to logs/debug_*.html
SCRAPER_DEBUG=0
